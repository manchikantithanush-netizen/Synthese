# Firebase API Keys - Copy this to .env and fill in your values
# DO NOT COMMIT .env FILE

# Web
FIREBASE_WEB_API_KEY=your_web_api_key_here
GOOGLE_WEB_CLIENT_ID=your_web_oauth_client_id_here

# Android
FIREBASE_ANDROID_API_KEY=your_android_api_key_here

# iOS
FIREBASE_IOS_API_KEY=your_ios_api_key_here

# GITHUB_TOKEN and WEATHER_API_KEY are stored as Cloudflare Worker secrets.
# Add them via: npx wrangler secret put GITHUB_TOKEN
#               npx wrangler secret put WEATHER_API_KEY
